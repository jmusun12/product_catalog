<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_product_catalog">
        <t t-call="web.html_container">
             <t t-foreach="docs" t-as="doc">
                <t t-call="product_catalog.report_product_catalog_pdf" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

    <template id="report_product_catalog_pdf">
        <xpath expr="//div[@class='header']" position="replace">
            <div class="header mb5" style="max-height: 200px !important;">
                <div class="content-header-image">
                    <img t-att-src="image_data_uri(doc.header_image)"
                         style="width: 100% !important;max-height: 122px;" alt="Logo"/>
                    <div class="center-title" t-esc="doc.title"></div>
                </div>
            </div>
        </xpath>
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>

            <div class="page">
                <div class="oe_structure"/>
                <div class="row" style="padding-top: 7px !important;">
                    <div class="col-12">
                        <table style="width: 100%; max-height: 200px !important;">
                            <tr>
                                <td style="width: 12%;">Nombre: </td>
                                <td colspan="3" style="width:35%; border-bottom: 2px solid #000000;">
                                    <span t-field="doc.partner_id.name"></span>
                                </td>
                                <td style="width: 4%;"><span></span></td>
                                <td style="width: 10%;">Fecha: </td>
                                <td style="width: 25%; border-bottom: 2px solid #000000;">
                                    <span t-field="doc.date_order"></span>
                                </td>
                            </tr>
                            <tr>
                                <td style="width: 12%;">Dirección: </td>
                                <td colspan="3" style="width: 35%;border-bottom: 2px solid #000000;">
                                    <span t-field="doc.partner_id.street"></span>
                                    <span t-field="doc.partner_id.street2"></span>
                                </td>
                                <td style="width: 4%;"><span></span></td>
                                <td style="width: 10%;">N°: </td>
                                <td style="width: 25%; border-bottom: 2px solid #000000;">
                                    <span t-field="doc.id"></span>
                                </td>
                            </tr>
                            <tr>
                                <td style="width: 12%;">Ciudad: </td>
                                <td style="width: 20%; border-bottom: 2px solid #000000;">
                                    <span t-field="doc.partner_id.city"></span>
                                </td>
                                <td style="border-bottom: 2px solid #000000;">Dept: </td>
                                <td style="border-bottom: 2px solid #000000;">
                                    <span t-field="doc.partner_id.state_id.name"></span>
                                </td>
                                <td style="width: 4%;"></td>
                                <td style="width: 10%;">Vendedor: </td>
                                <td style="width: 20%;border-bottom: 2px solid #000000;">
                                    <span t-field="doc.user_id.name"></span>
                                </td>
                           </tr>
                           <tr>
                                <td style="width: 12%;">Teléfono: </td>
                                <td style="width: 20%; border-bottom: 2px solid #000000;">
                                    <span t-field="doc.partner_id.city"></span>
                                </td>
                                <td style="">Fax: </td>
                                <td style="border-bottom: 2px solid #000000;">
                                    <span>No aplica</span>
                                </td>
                                <td style="width: 4%;"></td>
                                <td style="width: 10%;">Sucursal: </td>
                                <td style="width: 20%; border-bottom: 2px solid #000000;">
                                    <span t-field="doc.company_id.name"></span>
                                </td>
                            </tr>
                            <tr>
                                <td style="width: 12%;">Encargado(a): </td>
                                <td colspan="3" style="border-bottom: 2px solid #000000;">
                                </td>
                            </tr>
                            <tr>
                                <td style="width: 12%;">e-mail: </td>
                                <td colspan="3" style="width: 55%; border-bottom: 2px solid #000000;">
                                </td>
                            </tr>
                       </table>
                    </div>
                </div>

                <div class="row" style="padding-top: 10px !important;">
                   <div class="col-12 mb4">
                       <table style="width: 100%;" class="table table-bordered">
                           <thead style="color:black !important;">
                               <tr>
                                   <th class="text-center" style="width: 7%; vertical-align: middle !important; padding: 0.5rem !important;">
                                        Item
                                    </th>
                                   <th style="width: 10%;vertical-align: middle; padding: 0.5rem !important;" class="text-center">
                                        Cantidad
                                    </th>
                                   <th style="width: 15%; vertical-align: middle !important; padding: 0.5rem !important;" class="text-center">
                                        Código
                                    </th>
                                   <th style="width: 37%; vertical-align: middle !important; padding: 0.5rem !important;" class="text-center">
                                        Descripción
                                    </th>
                                   <th style="width: 12%; vertical-align: middle !important; padding: 0.5rem !important;" class="text-center">
                                        Precio Unitario con Descuento
                                    </th>
                                   <th style="width: 12%; vertical-align: middle !important; padding: 0.5rem !important;" class="text-center">
                                        Valor Total con Descuento
                                    </th>
                                   <th style="width: 12%; vertical-align: middle !important; padding: 0.5rem !important;" class="text-center">
                                        Imagen
                                    </th>
                               </tr>
                           </thead>
                           <tbody>
                                <t t-set="current_subtotal" t-value="0"/>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                    <tr>
                                        <td class="text-right" style="vertical-align: middle !important; padding: 0.5rem !important;">
                                            <span t-raw="line_index + 1"/>
                                        </td>
                                        <td class="text-right" style="vertical-align: middle !important; padding: 0.5rem !important;">
                                            <span t-field="line.product_uom_qty"/>
                                        </td>
                                        <td class="text-left" style="vertical-align: middle !important; padding: 0.5rem !important;">
                                            <span t-esc="int(round(line.product_uom_qty, 0))"/>
                                        </td>
                                        <td class="text-left" style="vertical-align: middle !important; padding: 0.5rem !important;">
                                            <t t-set="nombre" t-value="line.get_nombre(line.name)"/>
                                            <span t-esc="nombre"/>
                                        </td>
                                        <td class="text-right" style="vertical-align: middle !important; padding: 0.5rem !important;">
                                            <t t-if="line.discount > 0">
                                                <t t-set="subtotal" t-value="line.price_unit * 1.13"/>
                                                <t t-set="precioDescuento" t-value="subtotal - (subtotal * (line.discount/100))"/>
                                                <span t-esc="round(precioDescuento, 2)"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="round(line.price_unit * 1.13, 2)"/>
                                            </t>
                                        </td>
                                        <td class="text-right" style="vertical-align: middle !important; padding: 0.5rem !important;">
<!--                                            <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>-->
                                            <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                        <td style="vertical-align: middle !important; padding: 0.5rem !important;" class="text-left">
                                            <span t-field="line.order_line_image" t-options='{"widget": "image", "style": "max-height: 45px !important;"}'/>
                                        </td>
                                    </tr>
                                </t>
                           </tbody>
                       </table>
                   </div>
                </div>

                <div class="row" id="div-final">
                   <div class="col-8"></div>
                   <div class="col-3 text-center" style="border: 1px solid black; padding: 10px; border-radius: 25px;">
                        <span><strong>Total:  </strong></span> <span t-field="doc.amount_total"/>
                   </div>
                   <div class="col-1"></div>
                </div>

                <div class="row">
                   <div class="col-1"></div>
                   <div class="col-3 text-center">
                       <p style="margin: 0px; padding: 0px;"><span t-field="doc.user_id.name"></span></p>
                       <p>Firma y Sello del Ofertante</p>
                   </div>
                   <div class="col-5"></div>
                </div>

                 <!--Notas de la cotización-->
                <div class="row">
                    <div class="col-12 col-md-12 col-xl-12">
                        <p class="m-0 p-0"><strong><em>Nota: </em></strong></p>
                        <p class="text-justify" t-esc="doc.note"></p>
                    </div>
                </div>

                <div class="oe_structure"/>
            </div>

            <xpath expr="//div[@class='footer']" position="replace">
                <div class="footer">
                    <div class="oe_structure"/>
                    <div class="text-left" style="border-top: 7px solid black;">
                        <p class="text-uppercase"><span t-field="doc.company_id.name"/></p>
                        <div t-if="report_type == 'pdf'" class="text-muted">
                            Página: <span class="page"/> / <span class="topage"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </t>
        <style>
            /* encabezado */
            .content-header-image {
                position: relative;
                display: inline-block;
                text-align: center;
            }

            .center-title{
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }



            @media print {
                thead {
                    page-break-inside: avoid;
                }

                #div-final
                {
                    page-break-inside: avoid;
                }

                .header {
                    position: fixed;
                }

                .footer {
                    position: fixed;
                    bottom: 0;
                }
            }
            @page {
                size: Letter;
            }
        </style>
    </template>
</odoo>